generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  PERSONAL
  BUSINESS
}

enum DriverRole {
  DRIVER
  ADMIN
}

enum TenderCategory {
  EARTHWORKS
  LIFTING
  FREIGHT
  SAND_GRAVEL_DELIVERY
}

enum TenderStatus {
  OPEN
  EXPIRED
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String
  type             UserType  @default(PERSONAL)
  role             DriverRole @default(DRIVER)
  phone            String?
  city             String?
  balance          Int       @default(0)
  avatar           String?   @db.Text
  companyName      String?
  unp              String?
  description      String?   @db.Text
  companyAddress   String?
  verified          Boolean   @default(false)
  verificationToken String?   @unique
  businessCategory  String?
  schedule         String?
  website          String?
  welcomeMessage   String?   @db.Text
  ctaType          String?
  storeLogoImage       String?   @db.Text
  storeCoverImage      String?   @db.Text
  storeShortDescription String?  @db.VarChar(100)
  storeAccentColor     String?   @db.VarChar(20)
  customCategories     Json?     @default("[]")
  storeSearchSuggestionsEnabled Boolean @default(true)
  storeResponseMinutes Int?      @default(5)
  storeRating          Float?    @default(4.9)
  storeTelegram        String?   @db.VarChar(100)
  storeInstagram       String?   @db.VarChar(100)
  storeTiktok          String?   @db.VarChar(100)
  storeWhatsapp        String?   @db.VarChar(30)
  notifications    Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  listings            Listing[]
  catalogItems        CatalogItem[]
  analytics           Analytics?
  funnel              Funnel?
  promotions          Promotion[]
  searchSubscriptions SearchSubscription[]
  notificationList    Notification[]
  sessions            Session[]
  assignedTenders     Tender[]         @relation("TenderAssignedDriver")
  vehicles            Vehicle[]
  tenderResponses     TenderResponse[]
  adminAuditLogs      AdminAuditLog[]  @relation("AdminAuditActor")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  lastSeenAt DateTime?
  revokedAt DateTime?
  ip        String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Listing {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  price       Int
  image       String
  images      String[] @default([])
  views       Int     @default(0)
  rating      Float   @default(0)
  date        String
  active      Boolean @default(true)
  isVip       Boolean @default(false)
  oblast      String?
  raion       String?
  category    String?
  subcategory String?
  extraFields Json?
  sku         String?

  // Car-specific fields
  carBrandId      String?
  carBrand        CarBrand?      @relation(fields: [carBrandId], references: [id])
  carModelId      String?
  carModel        CarModel?      @relation(fields: [carModelId], references: [id])
  carGenerationId String?
  carGeneration   CarGeneration? @relation(fields: [carGenerationId], references: [id])
  carTrimId       String?
  carTrim         CarTrim?       @relation(fields: [carTrimId], references: [id])
  year            Int?
  mileage         Int?
  transmission    String?
  fuelType        String?
  engineVolume    Float?
  bodyType        String?
  driveType       String?
  color           String?
  equipment       Json?

  // Parts-specific fields
  partCategory String?
  partName     String?
  oemNumber    String?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  promotions Promotion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarBrand {
  id      String     @id @default(cuid())
  name    String     @unique
  logo    String?
  logoUrl String?
  models  CarModel[]
  listings Listing[]
}

model CarModel {
  id          String          @id @default(cuid())
  name        String
  vehicleType String          @default("car")
  brandId     String
  brand       CarBrand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  generations CarGeneration[]
  listings    Listing[]

  @@unique([brandId, name])
}

model CarGeneration {
  id        String   @id @default(cuid())
  name      String
  yearFrom  Int
  yearTo    Int?
  bodyType  String?
  modelId   String
  model     CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  trims     CarTrim[]
  listings  Listing[]
}

model CarTrim {
  id           String        @id @default(cuid())
  name         String
  engineVolume Float?
  fuelType     String?
  hp           Int?
  generationId String
  generation   CarGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  listings     Listing[]

  @@unique([generationId, name])
}

model CatalogItem {
  id          String @id @default(cuid())
  title       String
  price       Int
  image       String
  description String @db.Text

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analytics {
  id             String @id @default(cuid())
  profileViews   Int    @default(0)
  phoneViews     Int    @default(0)
  uniqueVisitors Int    @default(0)
  dailyViews     Int[]  @default([])
  audienceGeo    Json   @default("[]")
  audienceAge    Json   @default("[]")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model Funnel {
  id            String @id @default(cuid())
  profileVisits Int    @default(0)
  phoneClicks   Int    @default(0)
  websiteClicks Int    @default(0)
  ctaClicks     Int    @default(0)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model Promotion {
  id    String @id @default(cuid())
  coins Int
  date  String

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model SearchSubscription {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawQuery String  @db.Text
  filters  Json
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Tender {
  id               String         @id @default(cuid())
  category         TenderCategory
  address          String
  scheduledAt      DateTime
  customerPhone    String
  comment          String?        @db.Text
  expiresAt        DateTime
  status           TenderStatus   @default(OPEN)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedDriverId String?
  assignedDriver   User?          @relation("TenderAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  createdFromIp    String?
  createdFromUa    String?        @db.Text

  responses TenderResponse[]

  @@index([status])
  @@index([expiresAt])
  @@index([category])
  @@index([createdAt])
}

model Vehicle {
  id           String        @id @default(cuid())
  driverId     String
  driver       User          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  title        String
  category     TenderCategory
  payloadTons  Float?
  bodyVolumeM3 Float?
  plateNumber  String?
  status       VehicleStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  busySlots        VehicleBusySlot[]
  tenderResponses  TenderResponse[]

  @@index([driverId, status])
}

model VehicleBusySlot {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([startsAt])
  @@index([endsAt])
}

model TenderResponse {
  id           String   @id @default(cuid())
  tenderId     String
  tender       Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  driverId     String
  driver       User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleId    String?
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  message      String?  @db.Text
  offeredPrice Int?
  createdAt    DateTime @default(now())

  @@unique([tenderId, driverId])
  @@index([tenderId])
  @@index([driverId])
  @@index([vehicleId])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  adminUser   User     @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: Cascade)
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  policy      String
  key         String
  windowStart DateTime
  windowEnd   DateTime
  hits        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([policy, key, windowStart])
  @@index([windowEnd])
  @@index([policy, key, windowEnd])
}
